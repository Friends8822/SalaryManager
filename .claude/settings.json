{
  "permissions": {
    "allow": [
      "npm run dev --prefix 004.前端代码/salary-vue",
      "npm run build --prefix 004.前端代码/salary-vue",
      "npm run preview --prefix 004.前端代码/salary-vue",
      "cd 004.前端代码/salary-vue && npm install",
      "cd 006.后端代码/backend && ./mvnw spring-boot:run",
      "cd 006.后端代码/backend && ./mvnw clean package",
      "cd 006.后端代码/backend && ./mvnw test",
      "open http://localhost:5173",
      "open http://localhost:8080"
    ]
  },
  "hooks": {
    "PostCommit": [
      {
        "command": "cd 004.前端代码/salary-vue && npm run build",
        "description": "Build frontend after commit"
      }
    ],
    "EnterWorkingDirectory": [
      {
        "command": "echo '📁 SalaryManager Project - Frontend: npm run dev | Backend: ./mvnw spring-boot:run'",
        "description": "Show project context when entering directory"
      }
    ]
  },
  "env": {
    "VITE_API_BASE": "http://localhost:8080/api"
  },
  "model": "sonnet",
  "fastModel": "haiku"
}
